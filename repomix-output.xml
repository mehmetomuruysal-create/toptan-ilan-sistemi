      </button>

      {/* Kayıt Modalı */}
      <RegisterModal 
        isOpen={isRegisterOpen} 
        onClose={() => setIsRegisterOpen(false)} 
      />

      {/* Giriş Modalı */}
      <LoginModal 
        isOpen={isLoginOpen} 
        onClose={() => setIsLoginOpen(false)}
        onOpenRegister={() => setIsRegisterOpen(true)} // "Hesabım yok, kayıt ol" butonu için
      />
    </>
  )
}
</file>

