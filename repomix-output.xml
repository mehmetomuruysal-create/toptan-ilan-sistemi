<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HesapTuru {
  ALICI
  SATICI
}

model User {
  id                Int           @id @default(autoincrement())
  ad                String
  soyad             String
  email             String        @unique
  ulkeKodu          String        @default("+90")
  telefon           String?       @unique
  password          String
  cinsiyet          String?       
  kampanyaOnay      Boolean       @default(false)
  hesapTuru         HesapTuru     @default(ALICI)
  onayliTedarikci   Boolean       @default(false)
  firmaAdi          String?
  vergiNo           String?
  vergiDairesi      String?
  adres             String?
  teslimatAdresi    String?
  guvenPuani        Int           @default(100)
  
  // Admin yetkisi
  isAdmin           Boolean       @default(false)   // ✅ YENİ ALAN
  
  // Şifre Sıfırlama ve E-posta Onay Kodları
  resetToken        String?
  resetTokenExpiry  DateTime?
  epostaOnaylandi   Boolean       @default(false)
  emailVerifyToken  String?
  
  createdAt         DateTime      @default(now())
  
  ilanlar           Listing[]
  katilimlar        Participant[]
}

model Listing {
  id                Int      @id @default(autoincrement())
  baslik            String
  aciklama          String?
  urunUrl           String?
  kategori          String   @default("diger")
  perakendeFiyat    Float
  toptanFiyat       Float
  hedefSayi         Int
  hedefKitle        String   @default("hepsi")
  minMiktarBireysel Int      @default(1)
  minMiktarKobi     Int      @default(5)
  minMiktarKurumsal Int      @default(20)
  bitisTarihi       DateTime
  teslimatYontemi   String   @default("kargo")
  indirimOrani      Int      @default(10)
  depozitoOrani     Int      @default(30)
  durum             String   @default("aktif")
  saticiId          Int
  satici            User     @relation(fields: [saticiId], references: [id])
  havuzlar          Pool[]
  olusturmaTarihi   DateTime @default(now())
}

model Pool {
  id            Int           @id @default(autoincrement())
  ilanId        Int
  ilan          Listing       @relation(fields: [ilanId], references: [id])
  mevcutKatilim Int           @default(0)
  bitisTarihi   DateTime
  durum         String        @default("bekliyor")
  katilimcilar  Participant[]
}

model Participant {
  id           Int    @id @default(autoincrement())
  kullaniciId  Int
  kullanici    User   @relation(fields: [kullaniciId], references: [id])
  havuzId      Int
  havuz        Pool   @relation(fields: [havuzId], references: [id])
  talepMiktari Int
  odemeDurumu  String @default("bekliyor")
}
</file>

<file path="lib/mail.ts">
import { Resend } from 'resend';

const apiKey = process.env.RESEND_API_KEY;
const resend = apiKey ? new Resend(apiKey) : null;

const getBaseUrl = () => {
  if (process.env.NEXTAUTH_URL) return process.env.NEXTAUTH_URL;
  if (process.env.VERCEL_URL) return `https://${process.env.VERCEL_URL}`;
  return 'http://localhost:3000';
};

export async function sendVerificationEmail(email: string, ad: string, token: string) {
  const baseUrl = getBaseUrl();
  const verifyLink = `${baseUrl}/eposta-onay?token=${token}`;

  if (!resend) {
    console.error(`❌ RESEND_API_KEY eksik. Link: ${verifyLink}`);
    return;
  }

  try {
    const result = await resend.emails.send({
      from: 'Mingax <info@mingax.com>',
      to: email,
      subject: 'Mingax - E-posta Adresinizi Onaylayın',
      html: `<div><h2>Merhaba ${ad},</h2><p>Hesabınızı onaylamak için <a href="${verifyLink}">buraya tıklayın</a>.</p></div>`,
    });
    console.log('✅ Onay maili gönderildi:', result);
  } catch (error) {
    console.error('❌ Onay maili hatası:', error);
  }
}

export async function sendPasswordResetEmail(email: string, token: string) {
  const baseUrl = getBaseUrl();
  const resetLink = `${baseUrl}/sifre-yenile?token=${token}`;

  if (!resend) {
    console.error(`❌ RESEND_API_KEY eksik. Link: ${resetLink}`);
    return;
  }

  try {
    await resend.emails.send({
      from: 'Mingax <info@mingax.com>',
      to: email,
      subject: 'Mingax - Şifre Sıfırlama',
      html: `<div><p>Şifrenizi sıfırlamak için <a href="${resetLink}">tıklayın</a>.</p></div>`,
    });
  } catch (error) {
    console.error('Şifre sıfırlama hatası:', error);
  }
}
