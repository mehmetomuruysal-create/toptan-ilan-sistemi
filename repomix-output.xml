        >
          ✕
        </button>

        {success ? (
          <div className="text-center py-12 animate-in slide-in-from-bottom-4 duration-500">
            <div className="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-4xl mx-auto mb-6">
