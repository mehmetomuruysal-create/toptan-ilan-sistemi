                    <div className="font-bold text-gray-900">SATICI OLUYORUM</div>
                    <div className="text-xs text-gray-500 mt-2 text-center">Ürünlerimi toptan ve güvenle satmak istiyorum</div>
                  </button>
                </div>
              </div>
            )}

            {step === 2 && (
              <form onSubmit={handleSubmit} className="space-y-5 animate-in slide-in-from-right-8 duration-500">
                <div className="flex items-center justify-between mb-6 pb-4 border-b border-gray-100">
                  <div className="flex items-center gap-2">
                    <span className="text-2xl">{form.hesapTuru === "ALICI" ? "🛒" : "🏪"}</span>
                    <span className="font-bold text-gray-800">
                      {form.hesapTuru === "ALICI" ? "Alıcı Kaydı" : "Satıcı Kaydı"}
