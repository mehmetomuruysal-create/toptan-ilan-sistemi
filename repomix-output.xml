<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HesapTuru {
  ALICI
  SATICI
}

model User {
  id                Int           @id @default(autoincrement())
  ad                String
  soyad             String
  email             String        @unique
  ulkeKodu          String        @default("+90")
  telefon           String?       @unique
  password          String
  cinsiyet          String?       
  kampanyaOnay      Boolean       @default(false)
  hesapTuru         HesapTuru     @default(ALICI)
  onayliTedarikci   Boolean       @default(false)
  firmaAdi          String?
  vergiNo           String?
  vergiDairesi      String?
  adres             String?
  teslimatAdresi    String?
  guvenPuani        Int           @default(100)
  
  // Admin yetkisi
  isAdmin           Boolean       @default(false)
  
  // Şifre Sıfırlama ve E-posta Onay Kodları
  resetToken        String?
  resetTokenExpiry  DateTime?
  epostaOnaylandi   Boolean       @default(false)
  emailVerifyToken  String?
  
  createdAt         DateTime      @default(now())
  
  ilanlar           Listing[]
  katilimlar        Participant[]
  adresler          Address[]      // ✅ EKLENDI: Address modeli ile ilişki
}

model Listing {
  id                Int      @id @default(autoincrement())
  baslik            String
  aciklama          String?
  urunUrl           String?
  kategori          String   @default("diger")
  perakendeFiyat    Float
  toptanFiyat       Float
  hedefSayi         Int
  hedefKitle        String   @default("hepsi")
  minMiktarBireysel Int      @default(1)
  minMiktarKobi     Int      @default(5)
  minMiktarKurumsal Int      @default(20)
  bitisTarihi       DateTime
  teslimatYontemi   String   @default("kargo")
  indirimOrani      Int      @default(10)
  depozitoOrani     Int      @default(30)
  durum             String   @default("aktif")
  saticiId          Int
  satici            User     @relation(fields: [saticiId], references: [id])
  havuzlar          Pool[]
  olusturmaTarihi   DateTime @default(now())
}

model Pool {
  id            Int           @id @default(autoincrement())
  ilanId        Int
  ilan          Listing       @relation(fields: [ilanId], references: [id])
  mevcutKatilim Int           @default(0)
  bitisTarihi   DateTime
  durum         String        @default("bekliyor")
  katilimcilar  Participant[]
}

model Participant {
  id           Int    @id @default(autoincrement())
  kullaniciId  Int
  kullanici    User   @relation(fields: [kullaniciId], references: [id])
  havuzId      Int
  havuz        Pool   @relation(fields: [havuzId], references: [id])
  talepMiktari Int
  odemeDurumu  String @default("bekliyor")
}

enum FaturaTuru {
  BIREYSEL
  KURUMSAL
}

model Address {
  id                   Int        @id @default(autoincrement())
  userId               Int
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  baslik               String     // Örn: "Ev Adresim", "Merkez Ofis"
  teslimAlacakKisi     String     // Siparişi teslim alacak kişinin Adı Soyadı
  telefon              String     // Teslimat irtibat numarası
  
  il                   String
  ilce                 String
  mahalle              String?
  adresSatiri          String     // Sokak, bina, daire no
  postaKodu            String?
  
  isVarsayilanTeslimat Boolean    @default(false)
  isVarsayilanFatura   Boolean    @default(false)
  
  faturaTuru           FaturaTuru @default(BIREYSEL)
  tcKimlik             String?    // Bireysel fatura için
  firmaAdi             String?    // Kurumsal fatura için
  vergiDairesi         String?
  vergiNo              String?

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([userId])
}
</file>

