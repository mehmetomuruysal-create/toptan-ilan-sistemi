                {/* DÜZELTİLEN KISIM: Kontrolü session'dan değil veritabanından yapıyoruz */}
                {/* app/page.tsx içindeki kısmı böyle değiştir */}
{dbUser?.hesapTuru === "SATICI" && (
  <Link 
    href="/ilan-ekle" 
