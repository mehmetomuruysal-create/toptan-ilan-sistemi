                    {k.label}
                  </button>
                ))}
              </div>
            </div>

            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">Minimum Sipariş Miktarları</label>
              <div className="space-y-3">
                {[
                  { key: "minMiktarBireysel", label: "👤 Bireysel" },
                  { key: "minMiktarKobi", label: "🏪 KOBİ / Esnaf" },
