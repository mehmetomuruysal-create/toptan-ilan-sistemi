                    <button type="button" onMouseDown={() => setShowConfirm(true)} onMouseUp={() => setShowConfirm(false)} onMouseLeave={() => setShowConfirm(false)} className="absolute right-4 top-3.5 text-gray-400 hover:text-blue-600 transition-colors">👁️</button>
