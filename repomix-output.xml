                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <button onClick={() => { updateForm("hesapTuru", "ALICI"); setStep(2); }} className="relative flex flex-col items-center p-8 border-2 border-gray-100 rounded-2xl hover:border-blue-500 hover:shadow-lg transition-all duration-200 group bg-white">
                    <div className="w-16 h-16 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center text-3xl mb-4 group-hover:scale-110 transition-transform">🛒</div>
                    <div className="font-bold text-gray-900">ALICI OLUYORUM</div>
                    <div className="text-xs text-gray-500 mt-2 text-center">Toptan fiyatına avantajlı ürünler almak istiyorum</div>
                  </button>
                  <button onClick={() => { updateForm("hesapTuru", "SATICI"); setStep(2); }} className="relative flex flex-col items-center p-8 border-2 border-gray-100 rounded-2xl hover:border-green-500 hover:shadow-lg transition-all duration-200 group bg-white">
