generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMLAR (Sistemin Ticari ve Operasyonel Kimliği) ---

enum HesapTuru {
  ALICI
  SATICI
}

enum FaturaTuru {
  BIREYSEL
  KURUMSAL
}

enum ListingStatus {
  ACTIVE
  PENDING
  COMPLETED
  CANCELLED
  SUSPENDED
  REJECTED
  STOK_DOLDU
}

enum ParticipationStatus {
  PENDING
  CONFIRMED
  ACTIVE
  ONAYLANDI
  BAREM_TEKLIF_BEKLENIYOR
  TEKLIF_REDDEDILDI
  ZAMAN_ASIMI
  KAPORA_IADE
  KALAN_ODEME_BEKLENIYOR
  TAMAMLANDI
  CANCELLED
}

enum SupplierLevel {
  NONE
  BRONZ
  GUMUS
  ALTIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocType {
  VERGI_LEVHASI
  TICARI_SICIL
  IMZA_SIRKULERI
  FAALIYET_BELGESI
  IBAN_BELGESI
  SOZLESME
  BAKANLIK_IZNI
  DIGER
}

enum DocStatus {
  WAITING
  APPROVED
  REJECTED
}

enum DeliveryMethod {
  KARGO
  MERKEZI_TESLIM
  NAKLIYE
}

enum PointType {
  INITIATOR
  REFERRER
  SPENDING
  REFUND
}

enum DemandStatus {
  PENDING
  OFFERED
  APPROVED
  REJECTED
}

// --- MODELLER ---

model SystemSettings {
  id               Int   @id @default(1)
  defaultTotalComm Float @default(15.0)
  defaultMingaxNet Float @default(12.0)
  defaultInitRatio Float @default(0.75)
  defaultRefRatio  Float @default(2.25)
}

model User {
  id                Int                @id @default(autoincrement())
  ad                String
  soyad             String
  email             String             @unique
  ulkeKodu          String             @default("+90")
  telefon           String?            @unique
  password          String
  cinsiyet          String?
  kampanyaOnay      Boolean            @default(false)
  hesapTuru         HesapTuru          @default(ALICI)
  onayDurumu        UserStatus         @default(PENDING)
  tedarikciSeviye   SupplierLevel      @default(NONE)
  firmaAdi          String?
  vergiNo           String?            @unique
  vergiDairesi      String?
  tcKimlikNo        String?
  guvenPuani        Int                @default(100)
  epostaOnaylandi   Boolean            @default(false)
  emailVerifyToken  String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  isAdmin           Boolean            @default(false)
  pointsBalance     Float              @default(0)
  createdAt         DateTime           @default(now())
  ilanlar           Listing[]          @relation("SellerRelation")
  initiatedListings Listing[]          @relation("InitiatorRelation")
  demands           Demand[]
  katilimlar        Participant[]
  referredUsers     Participant[]      @relation("ReferrerRelation")
  pointTransactions PointTransaction[]
  adresler          Address[]
  belgeler          Document[]
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  commRatio Float?
  initRatio Float?
  refRatio  Float?
  listings  Listing[]
}

model Demand {
  id                 Int          @id @default(autoincrement())
  userId             Int
  user               User         @relation(fields: [userId], references: [id])
  urunAdi            String
  aciklama           String?
  markaTercihi       String?
  tahminiAdet        Int?
  durum              DemandStatus @default(PENDING)
  createdAt          DateTime     @default(now())
  convertedListingId Int?         @unique
}

model Listing {
  id                 Int               @id @default(autoincrement())
  baslik             String
  aciklama           String?
  urunUrl            String?
  bolge              String?
  il                 String?
  ilce               String?
  teslimatYontemleri DeliveryMethod[]
  categoryId         Int?
  category           Category?         @relation(fields: [categoryId], references: [id])
  perakendeFiyat     Float
  toptanFiyat        Float?
  hedefSayi          Int
  mevcutTalep        Int               @default(0)
  depozitoOrani      Int               @default(30)
  bitisTarihi        DateTime
  
  // 🚀 ALGORİTMA MÜHÜRLERİ (Durum A/B ve Race Condition Savunması)
  aktifBaremNo       Int?
  aktifBaremFiyat    Float?
  baremYukseltmeTuru Int               @default(0)
  version            Int               @default(0)

  isCampaign         Boolean           @default(false)
  specialComm        Float?
  specialInit        Float?
  specialRef         Float?
  saticiId           Int
  satici             User              @relation("SellerRelation", fields: [saticiId], references: [id])
  initiatorId        Int?
  initiator          User?             @relation("InitiatorRelation", fields: [initiatorId], references: [id])
  durum              ListingStatus     @default(PENDING)
  baremler           Barem[]
  images             ListingImage[]
  documents          ListingDocument[]
  katilimlar         Participant[]
  olusturmaTarihi    DateTime          @default(now())
}

model Barem {
  id           Int           @id @default(autoincrement())
  listingId    Int
  listing      Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sira         Int
  miktar       Int
  fiyat        Float
  katilimcilar Participant[]
  @@unique([listingId, sira])
}

model Participant {
  id                Int                 @id @default(autoincrement())
  kullaniciId       Int
  kullanici         User                @relation(fields: [kullaniciId], references: [id])
  
  // 🚀 TS HATASI ÇÖZÜMÜ: İlan bağlantısı mühürlendi
  ilanId            Int
  ilan              Listing             @relation(fields: [ilanId], references: [id])
  
  baremId           Int
  barem             Barem               @relation(fields: [baremId], references: [id])
  referrerId        Int?
  referrer          User?               @relation("ReferrerRelation", fields: [referrerId], references: [id])
  talepMiktari      Int
  
  // 💰 BAREM ALGORİTMASI VERİLERİ (İade ve Fiyat Koruma)
  secilenBaremFiyat Float
  kaporaMiktari     Float
  finalBaremFiyat   Float?
  kaporaIadeMiktari Float?
  kalanOdeme        Float?
  
  durum             ParticipationStatus @default(PENDING)
  teklifSonTarih    DateTime?
  teklifKarari      String?
  
  adresId           String?
  adres             Address?            @relation(fields: [adresId], references: [id])
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model PointTransaction {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  amount    Float
  type      PointType
  status    DocStatus @default(WAITING)
  createdAt DateTime  @default(now())
}

model Document {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tip           DocType
  fileUrl       String
  durum         DocStatus @default(WAITING)
  yuklemeTarihi DateTime  @default(now())
}

model ListingImage {
  id        Int     @id @default(autoincrement())
  url       String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingDocument {
  id        Int     @id @default(autoincrement())
  url       String
  name      String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Address {
  id                   String        @id @default(cuid())
  userId               Int
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  baslik               String
  teslimAlacakKisi     String
  telefon              String
  il                   String
  ilce                 String
  mahalle              String?
  adresSatiri          String
  postaKodu            String?
  isVarsayilanTeslimat Boolean       @default(false)
  isVarsayilanFatura   Boolean       @default(false)
  faturaTuru           FaturaTuru    @default(BIREYSEL)
  tcKimlik             String?
  firmaAdi             String?
  vergiDairesi         String?
  vergiNo              String?
  katilimlar           Participant[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}