generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMLAR ---

enum HesapTuru {
  ALICI
  SATICI
}

enum FaturaTuru {
  BIREYSEL
  KURUMSAL
}

enum ListingStatus {
  ACTIVE
  PENDING
  COMPLETED
  CANCELLED
  SUSPENDED // Admin veya kullanıcı tarafından dondurulan ilanlar
}

enum ParticipationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  SUSPENDED // Kullanıcı dondurulduğunda talepler bu duruma geçer
}

// --- MODELLER ---

model User {
  id                Int           @id @default(autoincrement())
  ad                String
  soyad             String
  email             String        @unique
  ulkeKodu          String        @default("+90")
  telefon           String?       @unique
  password          String
  cinsiyet          String?       
  kampanyaOnay      Boolean       @default(false)
  hesapTuru          HesapTuru     @default(ALICI)
  onayliTedarikci   Boolean       @default(false)
  firmaAdi          String?
  vergiNo           String?
  vergiDairesi      String?
  adres             String?
  teslimatAdresi    String?
  guvenPuani        Int           @default(100)
  isAdmin           Boolean       @default(false)
  resetToken        String?
  resetTokenExpiry  DateTime?
  epostaOnaylandi   Boolean       @default(false)
  emailVerifyToken  String?
  createdAt         DateTime      @default(now())
  
  ilanlar           Listing[]
  katilimlar        Participant[]
  adresler          Address[]
}

model Listing {
  id                Int           @id @default(autoincrement())
  baslik            String
  aciklama          String?
  urunUrl           String?
  kategori          String        @default("diger")
  perakendeFiyat    Float
  toptanFiyat       Float
  hedefSayi         Int
  hedefKitle        String        @default("hepsi")
  minMiktarBireysel Int           @default(1)
  minMiktarKobi      Int           @default(5)
  minMiktarKurumsal Int           @default(20)
  bitisTarihi       DateTime
  teslimatYontemi   String        @default("kargo")
  indirimOrani      Int           @default(10)
  depozitoOrani      Int           @default(30)
  
  durum             ListingStatus @default(ACTIVE)
  
  saticiId          Int
  satici            User          @relation(fields: [saticiId], references: [id], onDelete: Cascade)
  olusturmaTarihi   DateTime      @default(now())
  
  havuzlar          Pool[]
  baremler          Barem[]
}

model Barem {
  id           Int          @id @default(autoincrement())
  listingId    Int
  listing      Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sira         Int
  miktar       Int
  fiyat        Float
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  katilimcilar Participant[]

  @@unique([listingId, sira])
  @@index([listingId])
}

model Pool {
  id            Int           @id @default(autoincrement())
  ilanId        Int
  ilan          Listing       @relation(fields: [ilanId], references: [id], onDelete: Cascade)
  mevcutKatilim Int           @default(0)
  bitisTarihi   DateTime
  durum         String        @default("bekliyor")
  
  katilimcilar  Participant[]
}

model Participant {
  id           Int                 @id @default(autoincrement())
  kullaniciId  Int
  kullanici    User                @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  havuzId      Int
  havuz        Pool                @relation(fields: [havuzId], references: [id], onDelete: Cascade)
  talepMiktari Int
  
  durum        ParticipationStatus @default(PENDING)
  
  baremId      Int
  barem        Barem               @relation(fields: [baremId], references: [id], onDelete: Cascade)
}

model Address {
  id                   String     @id @default(cuid())
  userId               Int
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  baslik               String
  teslimAlacakKisi     String
  telefon              String
  il                   String
  ilce                 String
  mahalle              String?
  adresSatiri          String
  postaKodu            String?
  isVarsayilanTeslimat Boolean    @default(false)
  isVarsayilanFatura   Boolean    @default(false)
  faturaTuru           FaturaTuru @default(BIREYSEL)
  tcKimlik             String?
  firmaAdi             String?
  vergiDairesi         String?
  vergiNo              String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([userId])
}