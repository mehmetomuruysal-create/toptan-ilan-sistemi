generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMLAR (Sistemin Ticari ve Operasyonel Kimliği) ---

enum HesapTuru {
  ALICI
  SATICI
}

enum FaturaTuru {
  BIREYSEL
  KURUMSAL
}

enum ListingStatus {
  ACTIVE
  PENDING
  COMPLETED
  CANCELLED
  SUSPENDED
  REJECTED
  STOK_DOLDU
}

enum ParticipationStatus {
  PENDING
  CONFIRMED
  ACTIVE
  ONAYLANDI
  BAREM_TEKLIF_BEKLENIYOR
  TEKLIF_REDDEDILDI
  ZAMAN_ASIMI
  KAPORA_IADE
  KALAN_ODEME_BEKLENIYOR
  TAMAMLANDI
  CANCELLED
}

enum SupplierLevel {
  NONE
  BRONZ
  GUMUS
  ALTIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocType {
  VERGI_LEVHASI
  TICARI_SICIL
  IMZA_SIRKULERI
  FAALIYET_BELGESI
  IBAN_BELGESI
  SOZLESME
  BAKANLIK_IZNI
  DIGER
}

enum DocStatus {
  WAITING
  APPROVED
  REJECTED
}

enum DeliveryMethod {
  KARGO
  MERKEZI_TESLIM
  NAKLIYE
  MINGAX_NOKTA // 🚀 YENİ EKLENDİ
}

enum PointType {
  INITIATOR
  REFERRER
  SPENDING
  REFUND
}

enum DemandStatus {
  PENDING
  OFFERED
  APPROVED
  REJECTED
}

// 🚀 YENİ EKLENEN ENUMLAR (Teslimat Ağı İçin)

enum PaketDurumu {
  SIPARIS_ALINDI
  DEPODA_HAZIRLANIYOR
  KURYE_YOLDA
  NOKTADA
  TESLIM_EDILDI
  IADE_BEKLIYOR
  MINGAX_DEPOSUNDA
  IADE_TAMAMLANDI
}

enum NoktaSozlesmeDurumu {
  BEKLIYOR
  IMZALANDI
  FESHEDILDI
}

// --- MODELLER ---

model SystemSettings {
  id               Int   @id @default(1)
  defaultTotalComm Float @default(15.0)
  defaultMingaxNet Float @default(12.0)
  defaultInitRatio Float @default(0.75)
  defaultRefRatio  Float @default(2.25)
}

model User {
  id                Int                @id @default(autoincrement())
  ad                String
  soyad             String
  email             String             @unique
  ulkeKodu          String             @default("+90")
  telefon           String?            @unique
  password          String
  cinsiyet          String?
  kampanyaOnay      Boolean            @default(false)
  hesapTuru         HesapTuru          @default(ALICI)
  onayDurumu        UserStatus         @default(PENDING)
  tedarikciSeviye   SupplierLevel      @default(NONE)
  firmaAdi          String?
  vergiNo           String?            @unique
  vergiDairesi      String?
  tcKimlikNo        String?
  guvenPuani        Int                @default(100)
  epostaOnaylandi   Boolean            @default(false)
  emailVerifyToken  String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  isAdmin           Boolean            @default(false)
  pointsBalance     Float              @default(0)
  createdAt         DateTime           @default(now())
  ilanlar           Listing[]          @relation("SellerRelation")
  initiatedListings Listing[]          @relation("InitiatorRelation")
  demands           Demand[]
  katilimlar        Participant[]
  referredUsers     Participant[]      @relation("ReferrerRelation")
  pointTransactions PointTransaction[]
  adresler          Address[]
  belgeler          Document[]
}

model Category {
  id        Int        @id @default(autoincrement())
  googleId  Int?       
  name      String     
  slug      String     @unique
  
  parentId  Int?       
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")

  commRatio Float?
  initRatio Float?
  refRatio  Float?
  listings  Listing[]

  @@unique([name, parentId]) 
}

model Demand {
  id                 Int          @id @default(autoincrement())
  userId             Int
  user               User         @relation(fields: [userId], references: [id])
  urunAdi            String
  aciklama           String?
  markaTercihi       String?
  tahminiAdet        Int?
  durum              DemandStatus @default(PENDING)
  createdAt          DateTime     @default(now())
  convertedListingId Int?         @unique
}

model Listing {
  id                 Int              @id @default(autoincrement())
  baslik             String
  aciklama           String?
  urunUrl            String?
  bolge              String?
  il                 String?
  ilce               String?
  teslimatYontemleri DeliveryMethod[]
  categoryId         Int?
  category           Category?        @relation(fields: [categoryId], references: [id])
  perakendeFiyat     Float
  toptanFiyat        Float?
  hedefSayi          Int
  mevcutTalep        Int              @default(0)
  depozitoOrani      Int              @default(30)
  bitisTarihi        DateTime
  
  aktifBaremNo       Int?
  aktifBaremFiyat    Float?
  baremYukseltmeTuru Int              @default(0)
  version            Int              @default(0)

  isCampaign         Boolean          @default(false)
  specialComm        Float?
  specialInit        Float?
  specialRef         Float?
  saticiId           Int
  satici             User             @relation("SellerRelation", fields: [saticiId], references: [id])
  initiatorId        Int?
  initiator          User?            @relation("InitiatorRelation", fields: [initiatorId], references: [id])
  durum              ListingStatus    @default(PENDING)
  baremler           Barem[]
  images             ListingImage[]
  documents          ListingDocument[]
  katilimlar         Participant[]
  olusturmaTarihi    DateTime         @default(now())
}

model Barem {
  id           Int           @id @default(autoincrement())
  listingId    Int
  listing      Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sira         Int
  miktar       Int
  fiyat        Float
  katilimcilar Participant[]
  @@unique([listingId, sira])
}

model Participant {
  id                Int                 @id @default(autoincrement())
  kullaniciId       Int
  kullanici         User                @relation(fields: [kullaniciId], references: [id])
  ilanId            Int
  ilan              Listing             @relation(fields: [ilanId], references: [id])
  baremId           Int
  barem             Barem               @relation(fields: [baremId], references: [id])
  referrerId        Int?
  referrer          User?               @relation("ReferrerRelation", fields: [referrerId], references: [id])
  talepMiktari      Int
  secilenBaremFiyat Float
  kaporaMiktari     Float
  finalBaremFiyat   Float?
  kaporaIadeMiktari Float?
  kalanOdeme        Float?
  durum             ParticipationStatus @default(PENDING)
  teklifSonTarih    DateTime?
  teklifKarari      String?
  adresId           String?
  adres             Address?            @relation(fields: [adresId], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  paket             Paket?              // 🚀 YENİ EKLENDİ (Birebir İlişki)
}

model PointTransaction {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  amount    Float
  type      PointType
  status    DocStatus @default(WAITING)
  createdAt DateTime  @default(now())
}

model Document {
  id            Int       @id @default(autoincrement()) 
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tip           DocType
  fileUrl       String
  durum         DocStatus @default(WAITING)
  yuklemeTarihi DateTime  @default(now())
}

model ListingImage {
  id        Int     @id @default(autoincrement())
  url       String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingDocument {
  id        Int     @id @default(autoincrement())
  url       String
  name      String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Address {
  id                   String        @id @default(cuid())
  userId               Int
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  baslik               String
  teslimAlacakKisi     String
  telefon              String
  il                   String
  ilce                 String
  mahalle              String?
  adresSatiri          String
  postaKodu            String?
  isVarsayilanTeslimat Boolean       @default(false)
  isVarsayilanFatura   Boolean       @default(false)
  faturaTuru           FaturaTuru    @default(BIREYSEL)
  tcKimlik             String?
  firmaAdi             String?
  vergiDairesi         String?
  vergiNo              String?
  katilimlar           Participant[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

// 🚀 AŞAĞISI TAMAMEN YENİ EKLENEN MODELLER (Teslimat Noktası Ağı)

model TeslimatNoktasi {
  id                    Int       @id @default(autoincrement())
  ad                    String    // "Ahmet Bakkallı"
  esnafAdi              String    // İşletme sahibi tam adı
  telefon               String
  email                 String?

  adres                 String
  il                    String
  ilce                  String
  mahalle               String
  lat                   Float
  lng                   Float
  googlePlaceId         String?

  pazartesiAcilis       String?
  pazartesiKapanis      String?
  saliAcilis            String?
  saliKapanis           String?
  carsambaAcilis        String?
  carsambaKapanis       String?
  persembeAcilis        String?
  persembeKapanis       String?
  cumaAcilis            String?
  cumaKapanis           String?
  cumartesiAcilis       String?
  cumartesiKapanis      String?
  pazarAcilis           String?
  pazarKapanis          String?

  maxKapasite           Int
  mevcutKapasite        Int       @default(0)

  aktif                 Boolean   @default(true)
  geciciKapali          Boolean   @default(false)
  geciciKapaliBaslangic DateTime?
  geciciKapaliBitis     DateTime?
  geciciKapaliNeden     String?

  komisyonMiktari       Float
  komisyonMingaxPayi    Float
  komisyonTedarikciPayi Float
  toplamKazanilan       Float     @default(0)

  sozlesmeUrl           String?
  sozlesmeTarihi        DateTime?
  sozlesmeDurumu        NoktaSozlesmeDurumu @default(BEKLIYOR)

  esnafHesap            EsnafHesap?
  paketler              Paket[]
  komisyonIslemleri     KomisyonIslem[]

  olusturmaTarihi       DateTime  @default(now())
  guncellenmeTarihi     DateTime  @updatedAt
}

model EsnafHesap {
  id              Int             @id @default(autoincrement())
  noktaId         Int             @unique
  nokta           TeslimatNoktasi @relation(fields: [noktaId], references: [id], onDelete: Cascade)
  email           String          @unique
  password        String
  aktif           Boolean         @default(true)
  sonGirisTarihi  DateTime?
  cihazTuru       String?
  fcmToken        String?
  olusturmaTarihi DateTime        @default(now())
}

model Paket {
  id                  String       @id @default(cuid())
  
  katilimId           Int          @unique
  katilim             Participant  @relation(fields: [katilimId], references: [id], onDelete: Cascade)
  
  noktaId             Int?
  nokta               TeslimatNoktasi? @relation(fields: [noktaId], references: [id])

  agirlik             Float?
  boyut               String?

  kurye_qr            String       // Merkezden noktaya
  alici_qr            String       @unique // Alıcıdan noktaya
  iade_qr             String?      // İade için

  durum               PaketDurumu  @default(SIPARIS_ALINDI)

  noktayaBirakimTarihi DateTime?
  sonAlimTarihi        DateTime?
  teslimTarihi         DateTime?
  iadeBaslangicTarihi  DateTime?

  uc_gun_bildirimi     Boolean      @default(false)
  bir_gun_bildirimi    Boolean      @default(false)
  komisyonOdendi       Boolean      @default(false)

  olusturmaTarihi      DateTime     @default(now())
  guncellenmeTarihi    DateTime     @updatedAt
}

model KomisyonIslem {
  id              Int             @id @default(autoincrement())
  noktaId         Int
  nokta           TeslimatNoktasi @relation(fields: [noktaId], references: [id])
  paketId         String
  miktar          Float
  mingaxPayi      Float
  tedarikciPayi   Float
  odendi          Boolean         @default(false)
  odemeTarihi     DateTime?
  olusturmaTarihi DateTime        @default(now())
}